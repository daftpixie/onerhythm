{
  "name": "@onerhythm/web",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "next build",
    "check": "pnpm lint && pnpm typecheck",
    "clean": "rm -rf .turbo dist node_modules",
    "dev": "next dev --turbopack --hostname 127.0.0.1 --port 3001",
    "lint": "echo 'No dedicated web lint configuration yet.'",
    "start": "next start --hostname 0.0.0.0 --port ${PORT:-3001}",
    "test": "vitest run",
    "typecheck": "tsc --project tsconfig.typecheck.json --noEmit"
  },
  "dependencies": {
    "@onerhythm/types": "workspace:*",
    "@onerhythm/ui": "workspace:*",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "framer-motion": "^12.36.0",
    "lucide-react": "^0.577.0",
    "next": "15.5.10",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "recharts": "^3.8.0",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "22.13.14",
    "@types/react": "19.0.12",
    "@types/react-dom": "19.0.4",
    "@types/three": "^0.183.1",
    "autoprefixer": "10.4.21",
    "jsdom": "^26.1.0",
    "postcss": "8.5.3",
    "tailwindcss": "3.4.17",
    "typescript": "5.8.2",
    "vitest": "^3.2.4"
  }

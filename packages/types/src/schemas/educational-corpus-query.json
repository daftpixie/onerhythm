{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://onerhythm.dev/schemas/educational-corpus-query.json",
  "title": "EducationalCorpusQuery",
  "type": "object",
  "additionalProperties": false,
  "required": ["locale", "diagnosis_code", "content_sections", "profile_keywords"],
  "properties": {
    "locale": { "type": "string", "minLength": 2 },
    "diagnosis_code": {
      "type": "string",
      "enum": ["arvc", "afib", "vt", "svt", "long_qt", "brugada", "wpw", "other"]
    },
    "content_sections": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["condition_education", "doctor_questions", "recent_advancements", "mental_health_resources"]
      }
    },
    "profile_keywords": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}

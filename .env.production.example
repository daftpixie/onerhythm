# Web
NEXT_PUBLIC_ONERHYTHM_API_BASE_URL=https://api.onerhythm.org
NEXT_PUBLIC_ONERHYTHM_SITE_URL=https://onerhythm.org
NEXT_PUBLIC_LAUNCH_MODE=false
NEXT_PUBLIC_LAUNCH_URL=https://launch.onerhythm.org
NEXT_PUBLIC_LAUNCH_HOST=launch.onerhythm.org

# API
ONERHYTHM_ENV=production
LOG_LEVEL=INFO
BETA_MODE=invite_only
DATABASE_URL=postgresql+psycopg://postgres:change-me@db.onerhythm.internal/onerhythm?sslmode=require
DATABASE_MIGRATION_URL=postgresql+psycopg://postgres:change-me@db.onerhythm.internal/onerhythm?sslmode=require
AUTH_ALLOWED_ORIGINS=https://onerhythm.org,https://www.onerhythm.org,https://api.onerhythm.org
AUTH_SESSION_DURATION_DAYS=14
AUTH_MAX_ACTIVE_SESSIONS=5
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_DOMAIN=onerhythm.org
AUTH_COOKIE_SAMESITE=lax
REQUEST_ID_HEADER=X-Request-ID
ERROR_REPORTING_BACKEND=log
EXPORT_ARTIFACT_DIR=/var/lib/onerhythm/data_exports
MAX_UPLOAD_BYTES=10485760
MAX_PROCESSING_SECONDS=30
MAX_PDF_PROCESSING_SECONDS=90
MAX_PIPELINE_ATTEMPTS=2
MAX_WORKSPACE_AGE_SECONDS=3600
PUBLIC_RATE_LIMIT_REQUESTS=120
PUBLIC_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_REQUESTS=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
WAITLIST_RATE_LIMIT_REQUESTS=5
WAITLIST_RATE_LIMIT_WINDOW_SECONDS=3600
UPLOAD_RATE_LIMIT_REQUESTS=12
UPLOAD_RATE_LIMIT_WINDOW_SECONDS=300
EDUCATION_RATE_LIMIT_REQUESTS=30
EDUCATION_RATE_LIMIT_WINDOW_SECONDS=300
